{
    "admin_users": {
        "description": "管理员列表",
        "hint": "只有在此列表中的用户才有权限使用管理指令。Bot 管理员默认允许。",
        "type": "list",
        "default": []
    },
    "preview_module": {
        "type": "template_list",
        "description": "文件预览",
        "hint": "按群配置预览参数，群号为空表示全局生效。",
        "default": [
            {
                "group_id": "",
                "preview_length": 1000,
                "default_zip_password": "",
                "pdf_preview_pages": 1
            }
        ],
        "templates": {
            "default": {
                "name": "预览配置",
                "items": {
                    "group_id": {
                        "description": "群号",
                        "hint": "为空表示全局生效。",
                        "type": "string",
                        "default": ""
                    },
                    "preview_length": {
                        "description": "文本预览长度 (字符)",
                        "hint": "使用预览指令时，显示的内容预览的最大字符数。",
                        "type": "int",
                        "default": 1000
                    },
                    "default_zip_password": {
                        "description": "默认 ZIP 解压密码",
                        "hint": "在预览加密的 ZIP 压缩包时，会尝试使用此密码进行解压。",
                        "type": "string",
                        "default": ""
                    },
                    "pdf_preview_pages": {
                        "description": "PDF 预览页数",
                        "hint": "生成 PDF 预览图时的页数。",
                        "type": "int",
                        "slider": {
                            "min": 1,
                            "max": 10,
                            "step": 1
                        },
                        "default": 1
                    }
                }
            }
        }
    },
    "check_module": {
        "type": "template_list",
        "description": "文件检查",
        "hint": "配置单个群的容量监控与定时检查任务。",
        "default": [
            {
                "group_id": "",
                "scheduled_check_tasks": [],
                "scheduled_autodelete": false,
                "count_limit": 0,
                "space_limit_gb": 0
            }
        ],
        "templates": {
            "default": {
                "name": "检查配置",
                "items": {
                    "group_id": {
                        "description": "群号",
                        "hint": "配置目标群号，留空表示不生效。",
                        "type": "string",
                        "default": ""
                    },
                    "scheduled_check_tasks": {
                        "description": "定时失效文件检查任务",
                        "hint": "Cron 表达式（分 时 日 月 周），例如: 0 3 * * 1",
                        "type": "list",
                        "default": []
                    },
                    "scheduled_autodelete": {
                        "description": "自动删除失效文件",
                        "hint": "开启后，定时任务检测到失效文件将直接删除。",
                        "type": "bool",
                        "default": false
                    },
                    "count_limit": {
                        "description": "文件数量上限",
                        "hint": "超过此数量触发提醒，0 表示不监控。",
                        "type": "int",
                        "slider": {
                            "min": 0,
                            "max": 1500,
                            "step": 10
                        },
                        "default": 0
                    },
                    "space_limit_gb": {
                        "description": "空间上限 (GB)",
                        "hint": "超过此容量触发提醒，0 表示不监控。",
                        "type": "float",
                        "slider": {
                            "min": 0,
                            "max": 10,
                            "step": 0.01
                        },
                        "default": 0
                    }
                }
            }
        }
    },
    "backup_module": {
        "type": "template_list",
        "description": "文件备份",
        "hint": "按群配置备份参数，群号为空表示全局生效。",
        "default": [
            {
                "group_id": "",
                "backup_zip_password": "",
                "backup_file_size_limit_mb": 100,
                "backup_file_extensions": "txt,zip"
            }
        ],
        "templates": {
            "default": {
                "name": "备份配置",
                "items": {
                    "group_id": {
                        "description": "群号",
                        "hint": "为空表示全局生效。",
                        "type": "string",
                        "default": ""
                    },
                    "backup_zip_password": {
                        "description": "备份压缩包加密密码",
                        "hint": "使用指令备份文件时，生成的 ZIP 压缩包将使用此密码加密。留空则不加密。",
                        "type": "string",
                        "default": ""
                    },
                    "backup_file_size_limit_mb": {
                        "description": "单文件备份大小上限 (MB)",
                        "hint": "超过此大小的群文件将跳过备份。设置为 0 或不填则表示无限制。",
                        "type": "int",
                        "default": 100
                    },
                    "backup_file_extensions": {
                        "description": "允许备份的文件扩展名",
                        "hint": "只有在列表中的文件类型才会被备份。用逗号分隔，如: txt,pdf,jpg",
                        "type": "text",
                        "default": "txt,zip"
                    }
                }
            },
            "sync": {
                "name": "同步配置",
                "items": {
                    "source_group_id": {
                        "description": "源群群号",
                        "hint": "要同步的源群群号。",
                        "type": "string",
                        "default": ""
                    },
                    "target_group_id": {
                        "description": "目标群群号",
                        "hint": "同步到的目标群群号。",
                        "type": "string",
                        "default": ""
                    },
                    "sync_file_extensions": {
                        "description": "允许同步的文件扩展名",
                        "hint": "为空表示不限制。支持逗号分隔，如: txt,docx,pdf,jpg",
                        "type": "text",
                        "default": ""
                    },
                    "sync_file_size_limit_mb": {
                        "description": "文件同步大小上限 (MB)",
                        "hint": "超过此大小将跳过同步。0 表示不限制。",
                        "type": "int",
                        "default": 0
                    },
                    "purify_rules": {
                        "description": "文件名净化规则",
                        "hint": "同步前用于清洗文件名的正则表达式列表。",
                        "type": "list",
                        "default": []
                    },
                    "scheduled_sync_tasks": {
                        "description": "同步定时任务",
                        "hint": "Cron 表达式（分 时 日 月 周），例如: 0 3 * * 1",
                        "type": "list",
                        "default": []
                    }
                }
            }
        }
    }
}
